#!/usr/bin/env bash
# safe-step — friendly wrapper for the SafeStep team's Gemini-driven workflow.
#
# Hides the bits that aren't worth learning right now:
#   - branch creation
#   - commit message conventions
#   - finding the preview URL
#   - rolling back
#
# Usage:
#   safe-step new "<feature description>"   start a new isolated change
#   safe-step ai                             open Gemini CLI in this project
#   safe-step ship "<message>"               add + commit + push (preview URL)
#   safe-step sync                           pull latest main into your branch
#   safe-step preview                        open the preview URL
#   safe-step pr ["<title>"]                 open a PR to merge into the live app
#   safe-step undo                           revert the last commit you pushed
#   safe-step status                         what's changed, what branch you're on
#   safe-step prod                           open the production URL
#
# Run from anywhere in the project. No options, no flags.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$REPO_ROOT" ]]; then
  echo "✖ not inside a git repo" >&2
  exit 1
fi
cd "$REPO_ROOT"

PROD_URL="https://safestep-lisbon-one.vercel.app"

cmd="${1:-help}"
shift || true

slugify() {
  printf "%s" "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-+|-+$//g'
}

case "$cmd" in
  new)
    name="${1:-}"
    if [[ -z "$name" ]]; then
      echo "Usage: safe-step new \"<short feature description>\""
      exit 1
    fi
    branch="$(slugify "$name")"
    if [[ -z "$branch" ]]; then
      echo "✖ couldn't make a branch name from \"$name\""
      exit 1
    fi
    echo "→ fetching latest from GitHub..."
    git fetch origin --quiet
    if git rev-parse --verify --quiet "refs/heads/$branch" >/dev/null \
       || git rev-parse --verify --quiet "refs/remotes/origin/$branch" >/dev/null; then
      echo "✖ a branch called '$branch' already exists (yours or someone else's)."
      echo "  Try a different description, or 'git checkout $branch' to continue that work."
      exit 1
    fi
    git checkout main
    git pull --ff-only
    git checkout -b "$branch"
    # Warn if there are uncommitted changes hanging around from a previous session.
    if [[ -n "$(git status --porcelain)" ]]; then
      echo "ℹ note: you have uncommitted changes carried over from before. They're now on this branch."
    fi
    echo "✓ on branch '$branch'. Now ask Gemini what you want to build."
    ;;

  sync)
    branch="$(git symbolic-ref --short HEAD)"
    if [[ "$branch" == "main" ]]; then
      git pull --ff-only
      echo "✓ main is up to date."
      exit 0
    fi
    echo "→ pulling latest main and merging into '$branch'..."
    git fetch origin --quiet
    if ! git merge --no-edit origin/main; then
      echo
      echo "✖ merge conflict — someone else changed the same lines you did."
      echo "  Don't panic. Run 'safe-step ai' and tell Gemini:"
      echo "    \"there's a merge conflict — help me resolve it\""
      echo "  If Gemini can't sort it out, send the output of 'git status' to Diogo."
      exit 1
    fi
    echo "✓ '$branch' now includes the latest main."
    ;;

  ai)
    if ! command -v gemini >/dev/null 2>&1; then
      echo "✖ gemini CLI not installed. See: https://github.com/google-gemini/gemini-cli" >&2
      exit 1
    fi
    exec gemini
    ;;

  ship)
    msg="${1:-}"
    if [[ -z "$msg" ]]; then
      echo "Usage: safe-step ship \"<short message describing what changed>\""
      exit 1
    fi
    branch="$(git symbolic-ref --short HEAD)"
    if [[ "$branch" == "main" ]]; then
      echo "✖ you're on main. Run 'safe-step new <name>' first."
      exit 1
    fi
    echo "→ type-checking with pnpm build..."
    if ! pnpm build >/dev/null 2>&1; then
      echo "✖ build failed. Fix the errors, then 'safe-step ship' again."
      pnpm build  # re-run to show the errors
      exit 1
    fi
    git add -A
    if git diff --cached --quiet; then
      echo "✖ no changes to ship."
      exit 1
    fi
    git commit -m "$msg"
    echo "→ pushing to GitHub..."
    if ! git push -u origin "$branch" 2>&1; then
      echo
      echo "✖ push rejected. Usually this means main has moved since you started."
      echo "  Run 'safe-step sync' to pull main into your branch, then try again."
      exit 1
    fi
    echo
    echo "✓ shipped. Vercel is now building a preview."
    echo "  Run 'safe-step preview' in ~30s to see the URL."
    echo "  When it looks good, run 'safe-step pr' to ask for it to be merged into the live app."
    ;;

  pr)
    branch="$(git symbolic-ref --short HEAD)"
    if [[ "$branch" == "main" ]]; then
      echo "✖ you're on main. PRs come from feature branches."
      exit 1
    fi
    if ! command -v gh >/dev/null 2>&1; then
      echo "✖ GitHub CLI (gh) not installed."
      echo "  Open this URL to create the PR manually:"
      echo "  https://github.com/thesquaredD/safestep-lisbon/pull/new/$branch"
      exit 1
    fi
    title="${1:-$(git log -1 --pretty=%s)}"
    gh pr create --title "$title" --body "Preview: $(${0} preview)" --head "$branch" --base main
    ;;

  preview)
    branch="$(git symbolic-ref --short HEAD)"
    if [[ "$branch" == "main" ]]; then
      url="$PROD_URL"
    else
      # Vercel's preview URL convention:
      url="https://safestep-lisbon-git-${branch}-thesquaredds-projects.vercel.app"
    fi
    echo "$url"
    if command -v open >/dev/null 2>&1; then open "$url"; fi
    ;;

  prod)
    echo "$PROD_URL"
    if command -v open >/dev/null 2>&1; then open "$PROD_URL"; fi
    ;;

  undo)
    branch="$(git symbolic-ref --short HEAD)"
    if [[ "$branch" == "main" ]]; then
      echo "✖ refusing to undo on main. Make a new branch and revert there."
      exit 1
    fi
    last_msg="$(git log -1 --pretty=%s)"
    echo "→ this will revert the last commit: \"$last_msg\""
    read -r -p "  proceed? [y/N] " yn
    case "$yn" in
      y|Y|yes) ;;
      *) echo "  cancelled."; exit 0 ;;
    esac
    git revert --no-edit HEAD
    git push
    echo "✓ undone. The preview URL will redeploy without the bad change."
    ;;

  status)
    echo "branch:  $(git symbolic-ref --short HEAD)"
    echo "remote:  $(git config --get remote.origin.url)"
    echo
    echo "changes:"
    git status --short || true
    ;;

  help|--help|-h|"")
    sed -n '2,/^# Run from anywhere/p' "$0" | sed 's/^# \{0,1\}//'
    ;;

  *)
    echo "✖ unknown command: $cmd"
    echo "  run 'safe-step' to see available commands."
    exit 1
    ;;
esac
